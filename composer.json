{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "asmit/filament-upload": "^2.0",
        "blade-ui-kit/blade-heroicons": "^2.6",
        "codeat3/blade-eos-icons": "^1.15",
        "coolsam/modules": "^4.2",
        "danharrin/livewire-rate-limiting": "^2.1",
        "filament/actions": "^3.3",
        "filament/filament": "^3.3",
        "filament/forms": "^3.3",
        "filament/infolists": "^3.3",
        "filament/notifications": "^3.3",
        "filament/spatie-laravel-media-library-plugin": "^3.3",
        "filament/tables": "^3.3",
        "filament/widgets": "^3.3",
        "jeddsaliba/filament-messages": "^1.0",
        "jeffgreco13/filament-breezy": "^2.6",
        "joaopaulolndev/filament-edit-profile": "^1.0",
        "joaopaulolndev/filament-pdf-viewer": "^1.1",
        "laravel/framework": "^12.0",
        "laravel/ranger": "^0.1.8",
        "laravel/reverb": "^1.7",
        "laravel/sanctum": "^4.0",
        "laravel/slack-notification-channel": "^3.7",
        "laravel/socialite": "^5.24",
        "laravel/tinker": "^2.10.1",
        "livewire/flux": "^2.12",
        "livewire/livewire": "^3.7",
        "livewire/volt": "^1.10",
        "mallardduck/blade-boxicons": "^2.5",
        "microweber-deps/filament-modules": "^1.0",
        "nativephp/laravel": "^1.3",
        "nativephp/mobile": "^3.0",
        "nativephp/mobile-network": "^1.0",
        "nativephp/mobile-system": "^1.0",
        "pxlrbt/filament-excel": "^2.5",
        "savannabits/filament-modules": "^4.2",
        "shuvroroy/filament-spatie-laravel-health": "^2.3",
        "slym758/filament-collapsible-sidebar": "*",
        "slym758/filament-mobile-table": "^1.0",
        "spatie/laravel-activitylog": "^4.11",
        "spatie/laravel-backup": "^10.0",
        "spatie/laravel-medialibrary": "*",
        "spatie/laravel-menu": "^4.1",
        "spatie/laravel-package-tools": "^1.92",
        "spatie/laravel-permission": "^7.2",
        "spatie/yaml-front-matter": "^2.0",
        "srwiez/nativephp-mobile-screen": "^1.0",
        "stechstudio/filament-impersonate": "^3.3",
        "stichoza/google-translate-php": "^5.3",
        "symfony/expression-language": "^8.0",
        "tomatophp/filament-language-switcher": "^1.0",
        "ysfkaya/filament-phone-input": "^3.2"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "fakerphp/faker": "^1.23",
        "laravel-lang/common": "^6.7",
        "laravel-lang/lang": "^15.28",
        "laravel/boost": "^2.2",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3",
        "revolution/laravel-vercel-installer": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "vercel": [
            "npm install",
            "npm run build"
        ],
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"npm run dev\" --names='server,queue,vite'"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:meta"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "spatie/laravel-backup",
                "laravel/boost",
                "laravel/pail",
                "nativephp/laravel",
                "jeddsaliba/filament-messages",
                "joaopaulolndev/filament-edit-profile"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
