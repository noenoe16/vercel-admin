{
    "name": "slym758/filament-collapsible-sidebar",
    "description": "A Filament plugin that adds a collapsible sidebar with icon-only view",
    "keywords": [
        "filament",
        "laravel",
        "sidebar",
        "collapsible",
        "plugin"
    ],
    "homepage": "https://github.com/slym758/filament-collapsible-sidebar",
    "license": "MIT",
    "authors": [
        {
            "name": "Süleyman",
            "email": "your-email@example.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1|^8.2",
        "filament/filament": "^3.0|^4.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Slym758\\CollapsibleSidebar\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Slym758\\CollapsibleSidebar\\CollapsibleSidebarServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
